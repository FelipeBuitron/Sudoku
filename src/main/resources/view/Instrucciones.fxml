<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" stylesheets="@/styles.css"  prefWidth="600.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.InstruccionesController">
   <children>
      <Label fx:id="titulo"  styleClass="titulo" alignment="CENTER" contentDisplay="CENTER" prefHeight="66.0" prefWidth="600.0" text="SUDOKU">
      </Label>
      <VBox prefHeight="352.0" prefWidth="600.0">
         <children>
            <Label fx:id="subtitulo" styleClass="textoNegrillaDos" alignment="CENTER" prefHeight="70.0" prefWidth="600.0" text="INSTRUCCIONES">
            </Label>
            <Label fx:id="texto" styleClass="textoNegrillaDos" alignment="CENTER" prefHeight="17.0" prefWidth="606.0" text="Completa la cuadricula usando numeros del 1 al 6.">
            </Label>
            <Label alignment="CENTER" styleClass="textoNegrillaDos" contentDisplay="CENTER" prefHeight="17.0" prefWidth="616.0" text="Recuerda:">
            </Label>
            <Label alignment="CENTER" styleClass="texto" prefHeight="17.0" prefWidth="617.0" text=" ► No se pueden repetir números en una fila.">

            </Label>
            <Label alignment="CENTER" styleClass="texto" contentDisplay="CENTER" prefHeight="5.0" prefWidth="600.0" text="► No se pueden repetir números en una columna." textOverrun="WORD_ELLIPSIS" wrapText="true">
            </Label>
            <Label alignment="CENTER" styleClass="texto" contentDisplay="CENTER" prefHeight="17.0" prefWidth="668.0" text="► No se pueden repetir números en cada bloque de 2x3.">
            </Label>
            <Label alignment="CENTER" styleClass="texto" contentDisplay="CENTER" graphicTextGap="0.0" prefHeight="200.0" prefWidth="600.0" text="Selecciona una celda y escribe un número con el teclado. Si cometes un error, el juego lo indicará automáticamente." textAlignment="CENTER" wrapText="true">
            </Label>
            <Label  alignment="CENTER" styleClass="texto" prefHeight="17.0" prefWidth="607.0" text="Puedes usar el botón “Ayuda” para recibir una sugerencia.">
            </Label>
            <Label alignment="CENTER" styleClass="subtitulo" contentDisplay="CENTER" prefHeight="200.0" prefWidth="600.0" text="¡Completa el tablero correctamente para ganar!" textAlignment="CENTER" wrapText="true">
            </Label>
         </children>
      </VBox>
      <Button fx:id="botonVolver" styleClass="botonJuego" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#BotonRegresar" prefHeight="37.0" prefWidth="204.0" text="REGRESAR">
      </Button>
   </children>
   <opaqueInsets>
      <Insets />
   </opaqueInsets>
