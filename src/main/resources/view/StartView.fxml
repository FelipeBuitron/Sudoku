<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="352.0" prefWidth="377.0" spacing="20" style="-fx-background-image: url('/img/background.png'); -fx-background-size: cover;" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.StartController">

    <Label fx:id="titulo" text="SUDOKU">
      <font>
         <Font name="ROGFonts-Regular" size="58.0" />
      </font></Label>

    <Button fx:id="NuevoJuego" prefHeight="41.0" prefWidth="200.0" style="-fx-background-color: black;" text="INICIAR JUEGO" textFill="#f5f4f4" onAction="#starNewGame">
      <font>
         <Font name="Gill Sans Ultra Bold" size="17.0" />
      </font></Button>


    <Button fx:id="instrucciones" prefWidth="158.0" text="INSTRUCCIONES" onAction="#instructions">
      <font>
         <Font name="Cambria Math" size="18.0" />
      </font></Button>

</VBox>
